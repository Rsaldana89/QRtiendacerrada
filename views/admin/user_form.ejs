<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= mode === 'create' ? 'Nuevo usuario' : 'Editar usuario' %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="admin-page">
    <%- include('../partials/admin_header', { user, activeNav: 'usuarios' }) %>

    <main class="container admin-main narrow-main">
      <section class="page-head">
        <div>
          <div class="section-label">Usuarios</div>
          <h1><%= mode === 'create' ? 'Nuevo usuario' : 'Editar usuario' %></h1>
        </div>
        <a href="/admin/usuarios" class="btn btn-light">Volver</a>
      </section>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <section class="panel-card">
        <form action="<%= mode === 'create' ? '/admin/usuarios' : '/admin/usuarios/' + usuario.id %>" method="post" class="admin-form">
          <div class="form-grid two-cols">
            <div>
              <label for="nombre">Nombre *</label>
              <input id="nombre" name="nombre" required value="<%= usuario.nombre || '' %>" />
            </div>
            <div>
              <label for="username">Usuario *</label>
              <input id="username" name="username" required value="<%= usuario.username || '' %>" autocomplete="username" />
            </div>
            <div>
              <label for="password"><%= mode === 'create' ? 'Contraseña *' : 'Nueva contraseña' %></label>
              <div class="password-field">
                <input id="password" name="password" type="password" <%= mode === 'create' ? 'required' : '' %> autocomplete="new-password" />
                <button type="button" class="password-toggle" data-password-toggle="password" aria-label="Mostrar contraseña" aria-pressed="false" title="Mostrar contraseña">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M2.5 12s3.4-5.5 9.5-5.5 9.5 5.5 9.5 5.5-3.4 5.5-9.5 5.5S2.5 12 2.5 12Z"></path>
                    <circle cx="12" cy="12" r="2.8"></circle>
                  </svg>
                </button>
              </div>
              <% if (mode === 'edit') { %>
                <p class="help-text">Déjala vacía para conservar la actual.</p>
              <% } %>
            </div>
            <div>
              <label for="rol">Rol *</label>
              <select id="rol" name="rol" required>
                <option value="manager" <%= usuario.rol === 'manager' ? 'selected' : '' %>>Manager</option>
                <option value="usuario" <%= usuario.rol === 'usuario' || !usuario.rol ? 'selected' : '' %>>Usuario</option>
              </select>
              <p class="field-help">Manager administra. Usuario consulta reportes y sucursales.</p>
            </div>
          </div>

          <div class="switch-group">
            <label class="switch-row" for="activo">
              <span><strong>Usuario activo</strong></span>
              <input type="checkbox" id="activo" name="activo" value="1" <%= usuario.activo === undefined || Number(usuario.activo) === 1 ? 'checked' : '' %> />
            </label>
          </div>

          <div class="btn-row form-actions-end">
            <button type="submit" class="btn btn-primary btn-fit">Guardar usuario</button>
            <a href="/admin/usuarios" class="btn btn-light">Cancelar</a>
          </div>
        </form>
      </section>
    </main>
    <script src="/js/password-toggle.js"></script>
  </body>
</html>
