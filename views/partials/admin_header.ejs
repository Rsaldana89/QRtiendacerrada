<header class="header-admin">
  <div class="container nav-bar">
    <div class="nav-brand">
      <img src="/img/logo-chc.jpg" alt="Hermanos Coronel Cremería" />
      <div class="nav-brand-text">
        <strong>Tiendas cerradas</strong>
        <span>Panel de reportes QR</span>
      </div>
    </div>
    <div class="nav-actions">
      <div class="admin-nav-links">
        <a href="/admin" class="<%= activeNav === 'dashboard' ? 'active' : '' %>">Inicio</a>
        <a href="/admin/reportes" class="<%= activeNav === 'reportes' ? 'active' : '' %>">Reportes</a>
        <a href="/admin/sucursales" class="<%= activeNav === 'sucursales' ? 'active' : '' %>">Sucursales</a>
        <a href="/admin/usuarios" class="<%= activeNav === 'usuarios' ? 'active' : '' %>">Usuarios</a>
        <a href="/admin/configuracion" class="<%= activeNav === 'configuracion' ? 'active' : '' %>">Configuración</a>
      </div>
      <span class="user-pill">Hola, <%= user.nombre %></span>
      <form action="/logout" method="post" class="logout-form">
        <button type="submit" class="btn btn-logout">Salir</button>
      </form>
    </div>
  </div>
</header>
