# Copie este archivo a `.env` y rellene con sus credenciales antes de iniciar la aplicación.

# Configuración de la base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=su_contraseña
DB_NAME=qr_reports

# Clave secreta de la sesión
SESSION_SECRET=una_clave_secreta_segura

# Puerto de la aplicación
PORT=3000